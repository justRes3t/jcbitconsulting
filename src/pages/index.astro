---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="JCB IT Consulting helps businesses secure their infrastructure, achieve compliance, and manage risk with confidence.">

  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <p class="hero-tag">Security &amp; Consulting</p>
      <h1>Secure Your Business.<br/>Strengthen Your Future.</h1>
      <p class="hero-body">
        JCB IT Consulting delivers expert security assessments, compliance guidance,
        and risk management strategies so you can focus on growing your business
        — not worrying about threats.
      </p>
      <div class="hero-actions">
        <a href="/contact" class="btn btn--primary">Schedule a Consultation</a>
        <a href="/services" class="btn btn--outline">Explore Services</a>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="trust-bar">
    <div class="container">
      <div class="trust-grid">
        <div class="trust-item">
          <strong>100+</strong>
          <span>Security Assessments</span>
        </div>
        <div class="trust-item">
          <strong>15+</strong>
          <span>Years Experience</span>
        </div>
        <div class="trust-item">
          <strong>24/7</strong>
          <span>Incident Monitoring</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Services overview -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">What We Do</h2>
      <p class="section-subtitle">
        We help organizations identify vulnerabilities, meet regulatory requirements,
        and build resilient security programs from the ground up.
      </p>

      <div class="service-card service-card--featured">
        <div class="service-icon">&#128187;</div>
        <h3>IT Consulting</h3>
        <p>Strategic technology guidance from infrastructure assessments and cloud migrations to IT roadmapping — helping businesses make smarter technology decisions.</p>
      </div>

      <div class="grid grid--2 services-preview">
        <div class="service-card">
          <div class="service-icon">&#128274;</div>
          <h3>Security Assessments</h3>
          <p>Comprehensive vulnerability assessments, penetration testing, and security audits to uncover weaknesses before attackers do.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">&#9989;</div>
          <h3>Compliance Consulting</h3>
          <p>Navigate SOC 2, ISO 27001, and other frameworks with a clear roadmap and hands-on support.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">&#128200;</div>
          <h3>Risk Management</h3>
          <p>Identify, quantify, and mitigate business risk with tailored strategies that align security with your organizational goals.</p>
        </div>
        <div class="service-card">
          <div class="service-icon">&#128680;</div>
          <h3>Incident Response</h3>
          <p>Rapid containment, forensic investigation, and recovery planning when a security event occurs — available around the clock.</p>
        </div>
      </div>

      <div style="text-align:center; margin-top:2.5rem;">
        <a href="/services" class="btn btn--primary">View All Services</a>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="section section--dark cta-section">
    <div class="container" style="text-align:center;">
      <h2 class="section-title">Ready to Strengthen Your Security Posture?</h2>
      <p class="section-subtitle" style="margin-left:auto;margin-right:auto;">
        Whether you're building a security program from scratch or need an expert
        second opinion, we're here to help.
      </p>
      <a href="/contact" class="btn btn--primary">Get in Touch</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: var(--color-navy);
    color: var(--color-white);
    padding: 6rem 0 5rem;
  }
  .hero-inner { max-width: 720px; }
  .hero-tag {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: 1rem;
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }
  .hero-body {
    font-size: 1.1rem;
    color: var(--color-gray-400);
    line-height: 1.7;
    margin-bottom: 2rem;
  }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  /* Trust bar */
  .trust-bar {
    background: var(--color-navy-light);
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--color-navy-mid);
  }
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    text-align: center;
  }
  @media (min-width: 768px) {
    .trust-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .trust-item strong {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-accent);
  }
  .trust-item span {
    font-size: 0.85rem;
    color: var(--color-gray-400);
  }

  /* Service cards */
  .service-card {
    padding: 2rem;
    border: 1px solid var(--color-gray-200);
    border-radius: 8px;
    transition: box-shadow 0.2s;
  }
  .service-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
  }
  .service-card--featured {
    padding: 2rem;
    border: 2px solid var(--color-accent);
    border-radius: 8px;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, rgba(0, 191, 166, 0.04), transparent);
    transition: box-shadow 0.2s;
  }
  .service-card--featured:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
  }
  .service-icon {
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
  }
  .service-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .service-card p {
    font-size: 0.95rem;
    color: var(--color-gray-600);
    line-height: 1.6;
  }

  /* CTA */
  .cta-section { text-align: center; }
</style>
